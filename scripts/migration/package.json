{
  "name": "@wagdie/migration-scripts",
  "version": "1.0.0",
  "description": "Data migration scripts from Firestore to Supabase PostgreSQL",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "migrate": "node dist/cli/migrate.js",
    "export": "node dist/cli/export.js",
    "transform": "node dist/cli/transform.js",
    "import": "node dist/cli/import.js",
    "verify": "node dist/cli/verify.js",
    "test": "jest",
    "test:unit": "jest --testPathPattern=tests/unit",
    "test:integration": "jest --testPathPattern=tests/integration",
    "test:performance": "jest --testPathPattern=tests/performance",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "type-check": "tsc --noEmit",
    "migration:start": "node dist/cli/index.js start",
    "migration:status": "node dist/cli/index.js status",
    "migration:resume": "node dist/cli/index.js resume",
    "migration:validate": "node dist/cli/index.js validate",
    "migration:rollback": "node dist/cli/index.js rollback",
    "migration:pause": "node dist/cli/index.js pause",
    "migration:logs": "node dist/cli/index.js logs"
  },
  "keywords": [
    "migration",
    "firestore",
    "supabase",
    "postgresql",
    "wagdie",
    "web3"
  ],
  "author": "WAGDIE Community",
  "license": "MIT",
  "dependencies": {
    "firebase-admin": "^12.0.0",
    "@supabase/supabase-js": "^2.39.0",
    "ethers": "^6.10.0",
    "pino": "^8.17.0",
    "pino-pretty": "^10.3.0",
    "dotenv": "^16.3.1",
    "commander": "^11.1.0",
    "chalk": "^4.1.2",
    "ora": "^5.4.1",
    "inquirer": "^8.2.6"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.11",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
