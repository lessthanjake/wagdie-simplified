# Test Environment Configuration for Migration Framework
NODE_ENV=test
LOG_LEVEL=debug

# WAGDIE Supabase Local Docker for Testing
SUPABASE_URL=http://localhost:8010
SUPABASE_ANON_KEY=test-anon-key
SUPABASE_SERVICE_ROLE_KEY=test-service-role-key

# Migration Test Configuration
DEFAULT_BATCH_SIZE=10
DEFAULT_PARALLEL_BATCHES=1
DEFAULT_CHECKPOINT_INTERVAL=50
DEFAULT_MAX_ERROR_RATE=0.05
DRY_RUN=true